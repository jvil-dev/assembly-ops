generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id                String             @id @default(cuid())
  email             String             @unique
  passwordHash      String?
  firstName         String
  lastName          String
  phone             String?
  congregation      String? // Optional - set during profile completion
  congregationId    String? // NEW: FK to Congregation
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendanceCounts    AttendanceCount[]
  checkIns            CheckIn[]
  events              EventAdmin[]
  sentMessages        Message[]          @relation("MessageSenderAdmin")
  legacySentMessages  Message[]          @relation("MessageLegacySender")
  refreshTokens       RefreshToken[]
  eventNotes          EventNote[]
  oauthConnections    OAuthConnection[]
  congregationRef     Congregation?      @relation(fields: [congregationId], references: [id])
  safetyIncidents     SafetyIncident[]
  lostPersonAlerts    LostPersonAlert[]
  attendantMeetings   AttendantMeeting[]

  @@index([email])
  @@index([congregationId])
}

model AttendanceCount {
  id            String   @id @default(cuid())
  count         Int
  section       String?
  notes         String?
  sessionId     String
  postId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  submittedById String
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  post          Post?    @relation(fields: [postId], references: [id])
  submittedBy   Admin    @relation(fields: [submittedById], references: [id])

  @@unique([sessionId, section])
  @@index([sessionId])
  @@index([postId])
}

model AttendantMeeting {
  id          String              @id @default(cuid())
  session     Session             @relation(fields: [sessionId], references: [id])
  sessionId   String
  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId     String
  meetingDate DateTime
  notes       String?
  createdBy   Admin               @relation(fields: [createdById], references: [id])
  createdById String
  attendees   MeetingAttendance[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([eventId])
}

model CheckIn {
  id               String             @id @default(cuid())
  checkInTime      DateTime           @default(now())
  checkOutTime     DateTime?
  assignmentId     String             @unique
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  checkedInById    String?
  checkedInByVolId String? // NEW: Captain (EventVolunteer) who checked in
  notes            String?
  status           CheckInStatus      @default(CHECKED_IN)
  assignment       ScheduleAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  checkedInBy      Admin?             @relation(fields: [checkedInById], references: [id])
  checkedInByVol   EventVolunteer?    @relation(fields: [checkedInByVolId], references: [id])

  @@index([assignmentId])
}

model Circuit {
  id             String          @id @default(cuid())
  code           String          @unique
  region         String
  language       String          @default("E")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  congregations  Congregation[]
  eventTemplates EventTemplate[]

  @@index([region])
  @@index([language])
}

model Congregation {
  id                String             @id @default(cuid())
  name              String
  city              String
  state             String
  language          String             @default("E")
  circuitId         String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  circuit           Circuit            @relation(fields: [circuitId], references: [id], onDelete: Cascade)
  volunteerProfiles VolunteerProfile[]
  admins            Admin[]

  @@unique([name, city, state])
  @@index([circuitId])
  @@index([state, language])
}

model Department {
  id              String           @id @default(cuid())
  name            String
  departmentType  DepartmentType
  description     String?
  eventId         String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  event           Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  overseer        EventAdmin?
  notes           EventNote[]
  posts           Post[]
  areas           Area[]
  volunteers      Volunteer[] // Keep during migration
  eventVolunteers EventVolunteer[] // NEW

  @@unique([eventId, departmentType])
  @@index([eventId])
}

model Event {
  id                 String             @id @default(cuid())
  templateId         String
  joinCode           String             @unique @default(cuid())
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  acceptDeadlineDays Int                @default(5)
  departments        Department[]
  template           EventTemplate      @relation(fields: [templateId], references: [id])
  admins             EventAdmin[]
  notes              EventNote[]
  messages           Message[]
  roles              Role[]
  sessions           Session[]
  volunteers         Volunteer[]
  eventVolunteers    EventVolunteer[]
  safetyIncidents        SafetyIncident[]
  lostPersonAlerts       LostPersonAlert[]
  attendantMeetings      AttendantMeeting[]
  walkThroughCompletions WalkThroughCompletion[]
  facilityLocations      FacilityLocation[]
  conversations          Conversation[]

  @@index([joinCode])
  @@index([templateId])
}

model EventAdmin {
  id           String      @id @default(cuid())
  adminId      String
  eventId      String
  role         EventRole
  departmentId String?     @unique
  claimedAt    DateTime    @default(now())
  admin        Admin       @relation(fields: [adminId], references: [id], onDelete: Cascade)
  department   Department? @relation(fields: [departmentId], references: [id])
  event        Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([adminId, eventId])
  @@index([adminId])
  @@index([eventId])
}

model EventNote {
  id           String      @id @default(cuid())
  title        String?
  body         String
  eventId      String
  departmentId String?
  createdById  String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  event        Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy    Admin       @relation(fields: [createdById], references: [id])

  @@index([departmentId])
  @@index([eventId])
}

model EventTemplate {
  id             String    @id @default(cuid())
  eventType      EventType
  circuit        String? // Keep for backward compat during migration
  circuitId      String? // NEW: FK to Circuit
  region         String
  serviceYear    Int
  name           String
  theme          String?
  themeScripture String?
  venue          String
  address        String
  startDate      DateTime
  endDate        DateTime
  language       String    @default("en")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  events         Event[]
  circuitRef     Circuit?  @relation(fields: [circuitId], references: [id])

  @@unique([eventType, circuit, startDate])
  @@index([region])
  @@index([serviceYear])
  @@index([circuitId])
}

model EventVolunteer {
  id                 String               @id @default(cuid())
  volunteerId        String               @unique // "CA-XXXXX" or "RC-XXXXXX"
  tokenHash          String // bcrypt hash for auth
  token              String
  volunteerProfileId String
  eventId            String
  departmentId       String?
  roleId             String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  volunteerProfile   VolunteerProfile     @relation(fields: [volunteerProfileId], references: [id])
  event              Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  department         Department?          @relation(fields: [departmentId], references: [id])
  role               Role?                @relation(fields: [roleId], references: [id])
  assignments        ScheduleAssignment[]
  checkIns           CheckIn[]
  sentMessages       Message[]          @relation("MessageSenderVol")
  legacyMessages     Message[]          @relation("MessageLegacyRecipient")
  refreshTokens      RefreshToken[]
  safetyIncidents        SafetyIncident[]
  lostPersonAlerts       LostPersonAlert[]
  meetingAttendances     MeetingAttendance[]
  areaCaptains           AreaCaptain[]
  walkThroughCompletions WalkThroughCompletion[]
  postSessionStatuses    PostSessionStatus[]     @relation("PostSessionStatusUpdatedBy")

  @@unique([volunteerProfileId, eventId]) // One profile per event
  @@index([eventId])
  @@index([departmentId])
  @@index([volunteerProfileId])
}

model LostPersonAlert {
  id               String         @id @default(cuid())
  personName       String
  age              Int?
  description      String
  lastSeenLocation String?
  lastSeenTime     DateTime?
  contactName      String
  contactPhone     String?
  reportedBy       EventVolunteer @relation(fields: [reportedById], references: [id])
  reportedById     String
  event            Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId          String
  resolved         Boolean        @default(false)
  resolvedAt       DateTime?
  resolvedBy       Admin?         @relation(fields: [resolvedById], references: [id])
  resolvedById     String?
  resolutionNotes  String?
  createdAt        DateTime       @default(now())
  session          Session?       @relation(fields: [sessionId], references: [id])
  sessionId        String?

  @@index([eventId])
  @@index([resolved])
}

model MeetingAttendance {
  id               String           @id @default(cuid())
  meeting          AttendantMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  meetingId        String
  eventVolunteer   EventVolunteer   @relation(fields: [eventVolunteerId], references: [id])
  eventVolunteerId String
  createdAt        DateTime         @default(now())
  session          Session?         @relation(fields: [sessionId], references: [id])
  sessionId        String?

  @@unique([meetingId, eventVolunteerId])
}

model Message {
  id                 String            @id @default(cuid())
  subject            String?
  body               String
  recipientType      RecipientType
  recipientId        String
  isRead             Boolean           @default(false)
  readAt             DateTime?
  eventId            String
  // New polymorphic sender identity
  senderType         MessageSenderType?
  senderAdminId      String?
  senderVolId        String?
  // Conversation threading (null for broadcasts)
  conversationId     String?
  // Soft delete flags
  deletedBySender    Boolean           @default(false)
  deletedByRecipient Boolean           @default(false)
  // Legacy fields (kept for backward compatibility)
  senderId           String?
  volunteerId        String?
  eventVolunteerId   String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  event              Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  senderAdmin        Admin?            @relation("MessageSenderAdmin", fields: [senderAdminId], references: [id])
  senderVol          EventVolunteer?   @relation("MessageSenderVol", fields: [senderVolId], references: [id], onDelete: Cascade)
  conversation       Conversation?     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  // Legacy relations
  sender             Admin?            @relation("MessageLegacySender", fields: [senderId], references: [id])
  volunteer          Volunteer?        @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  eventVolunteer     EventVolunteer?   @relation("MessageLegacyRecipient", fields: [eventVolunteerId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([conversationId])
  @@index([senderType, senderAdminId])
  @@index([senderType, senderVolId])
  @@index([recipientType, recipientId])
  @@index([volunteerId])
  @@index([eventVolunteerId])
}

model Conversation {
  id           String                    @id @default(cuid())
  eventId      String
  subject      String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  event        Event                     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  messages     Message[]
  participants ConversationParticipant[]

  @@index([eventId])
}

model ConversationParticipant {
  id              String            @id @default(cuid())
  conversationId  String
  participantType MessageSenderType
  participantId   String
  lastReadAt      DateTime?
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  conversation    Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, participantType, participantId])
  @@index([participantType, participantId])
  @@index([conversationId])
}

model OAuthConnection {
  id         String       @id @default(cuid())
  provider   AuthProvider
  providerId String
  email      String?
  adminId    String
  createdAt  DateTime     @default(now())
  admin      Admin        @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([adminId])
}

model Post {
  id               String               @id @default(cuid())
  name             String
  description      String?
  location         String?
  capacity         Int                  @default(1)
  category         String?
  sortOrder        Int                  @default(0)
  departmentId     String
  areaId           String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  department          Department           @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  area                Area?                @relation(fields: [areaId], references: [id], onDelete: Cascade)
  assignments         ScheduleAssignment[]
  attendanceCounts    AttendanceCount[]
  incidents           SafetyIncident[]
  postSessionStatuses PostSessionStatus[]

  @@index([departmentId])
  @@index([areaId])
}

model RefreshToken {
  id               String          @id @default(cuid())
  token            String          @unique
  expiresAt        DateTime
  revoked          Boolean         @default(false)
  adminId          String?
  volunteerId      String? // OLD
  eventVolunteerId String? // NEW
  createdAt        DateTime        @default(now())
  admin            Admin?          @relation(fields: [adminId], references: [id], onDelete: Cascade)
  volunteer        Volunteer?      @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  eventVolunteer   EventVolunteer? @relation(fields: [eventVolunteerId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
  @@index([token])
  @@index([volunteerId])
  @@index([eventVolunteerId])
}

model Role {
  id              String           @id @default(cuid())
  name            String
  description     String?
  sortOrder       Int              @default(0)
  eventId         String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  event           Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  volunteers      Volunteer[] // OLD
  eventVolunteers EventVolunteer[] // NEW

  @@unique([eventId, name])
  @@index([eventId])
}

model SafetyIncident {
  id              String             @id @default(cuid())
  type            SafetyIncidentType
  description     String
  location        String?
  post            Post?              @relation(fields: [postId], references: [id])
  postId          String?
  reportedBy      EventVolunteer     @relation(fields: [reportedById], references: [id])
  reportedById    String
  event           Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId         String
  resolved        Boolean            @default(false)
  resolvedAt      DateTime?
  resolvedBy      Admin?             @relation(fields: [resolvedById], references: [id])
  resolvedById    String?
  resolutionNotes String?
  createdAt       DateTime           @default(now())
  session         Session?           @relation(fields: [sessionId], references: [id])
  sessionId       String?

  @@index([eventId])
  @@index([resolved])
}

model ScheduleAssignment {
  id               String           @id @default(cuid())
  volunteerId      String? // OLD: FK to Volunteer (nullable during migration)
  eventVolunteerId String? // NEW: FK to EventVolunteer
  postId           String
  sessionId        String
  status           AssignmentStatus @default(PENDING)
  isCaptain        Boolean          @default(false)
  respondedAt      DateTime?
  declineReason    String?
  acceptedDeadline DateTime?
  forceAssigned    Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  checkIn          CheckIn?
  post             Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  session          Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  volunteer        Volunteer?       @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  eventVolunteer   EventVolunteer?  @relation(fields: [eventVolunteerId], references: [id], onDelete: Cascade)

  @@unique([volunteerId, sessionId])
  @@unique([eventVolunteerId, sessionId])
  @@index([postId])
  @@index([sessionId])
  @@index([volunteerId])
  @@index([eventVolunteerId])
  @@index([status])
}

model Session {
  id                 String               @id @default(cuid())
  name               String
  date               DateTime             @db.Date
  startTime          DateTime             @db.Time(6)
  endTime            DateTime             @db.Time(6)
  eventId            String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  attendanceCounts   AttendanceCount[]
  assignments        ScheduleAssignment[]
  event              Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  safetyIncidents        SafetyIncident[]
  lostPersonAlerts       LostPersonAlert[]
  meetingAttendances     MeetingAttendance[]
  attendantMeetings      AttendantMeeting[]
  areaCaptains           AreaCaptain[]
  walkThroughCompletions WalkThroughCompletion[]
  postSessionStatuses    PostSessionStatus[]

  @@index([date])
  @@index([eventId])
}

model Volunteer {
  id                String               @id @default(cuid())
  volunteerId       String               @unique
  tokenHash         String
  encryptedToken    String?
  firstName         String
  lastName          String
  email             String?
  phone             String?
  congregation      String
  appointmentStatus AppointmentStatus?   @default(PUBLISHER)
  notes             String?
  eventId           String
  departmentId      String?
  roleId            String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  messages          Message[]
  refreshTokens     RefreshToken[]
  assignments       ScheduleAssignment[]
  department        Department?          @relation(fields: [departmentId], references: [id])
  event             Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  role              Role?                @relation(fields: [roleId], references: [id])

  @@index([departmentId])
  @@index([eventId])
  @@index([volunteerId])
}

model VolunteerProfile {
  id                String            @id @default(cuid())
  firstName         String
  lastName          String
  email             String?
  phone             String?
  appointmentStatus AppointmentStatus @default(PUBLISHER)
  notes             String?
  congregationId    String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  congregation      Congregation      @relation(fields: [congregationId], references: [id])
  eventVolunteers   EventVolunteer[]

  @@index([congregationId])
  @@index([lastName, firstName])
}

model Area {
  id           String        @id @default(cuid())
  name         String
  description  String?
  category     String?
  sortOrder    Int           @default(0)
  departmentId String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  department   Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  posts        Post[]
  captains     AreaCaptain[]

  @@unique([departmentId, category, name])
  @@index([departmentId])
}

model AreaCaptain {
  id               String         @id @default(cuid())
  areaId           String
  sessionId        String
  eventVolunteerId String
  createdAt        DateTime       @default(now())
  area             Area           @relation(fields: [areaId], references: [id], onDelete: Cascade)
  session          Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventVolunteer   EventVolunteer @relation(fields: [eventVolunteerId], references: [id], onDelete: Cascade)

  @@unique([areaId, sessionId])
  @@index([eventVolunteerId])
  @@index([sessionId])
}

model WalkThroughCompletion {
  id               String         @id @default(cuid())
  eventId          String
  sessionId        String
  eventVolunteerId String
  completedAt      DateTime       @default(now())
  itemCount        Int
  notes            String?
  event            Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  session          Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventVolunteer   EventVolunteer @relation(fields: [eventVolunteerId], references: [id], onDelete: Cascade)

  @@index([eventId, sessionId])
  @@index([eventVolunteerId])
}

model PostSessionStatus {
  id          String               @id @default(cuid())
  postId      String
  sessionId   String
  status      SeatingSectionStatus @default(OPEN)
  updatedById String
  updatedAt   DateTime             @updatedAt
  post        Post                 @relation(fields: [postId], references: [id], onDelete: Cascade)
  session     Session              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  updatedBy   EventVolunteer       @relation("PostSessionStatusUpdatedBy", fields: [updatedById], references: [id])

  @@unique([postId, sessionId])
  @@index([sessionId])
}

model FacilityLocation {
  id          String  @id @default(cuid())
  eventId     String
  name        String
  location    String
  description String?
  sortOrder   Int     @default(0)
  event       Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

enum AppointmentStatus {
  PUBLISHER
  MINISTERIAL_SERVANT
  ELDER
}

enum AssignmentStatus {
  PENDING
  ACCEPTED
  DECLINED
  AUTO_DECLINED
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
}

enum CheckInStatus {
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
}

enum DepartmentType {
  ACCOUNTS
  ATTENDANT
  AUDIO_VIDEO
  BAPTISM
  CLEANING
  FIRST_AID
  INFORMATION_VOLUNTEER_SERVICE
  INSTALLATION
  LOST_FOUND_CHECKROOM
  PARKING
  ROOMING
  TRUCKING_EQUIPMENT
}

enum EventRole {
  APP_ADMIN
  DEPARTMENT_OVERSEER
}

enum EventType {
  CIRCUIT_ASSEMBLY
  REGIONAL_CONVENTION
  SPECIAL_CONVENTION
}

enum RecipientType {
  VOLUNTEER
  DEPARTMENT
  EVENT
  ADMIN
}

enum MessageSenderType {
  ADMIN
  VOLUNTEER
}

enum SeatingSectionStatus {
  OPEN
  FILLING
  FULL
}

enum SafetyIncidentType {
  BUILDING_DEFECT
  WET_FLOOR
  UNSAFE_CONDITION
  MEDICAL_EMERGENCY
  DISRUPTIVE_INDIVIDUAL
  BOMB_THREAT
  VIOLENT_INDIVIDUAL
  SEVERE_WEATHER
  ACTIVE_SHOOTER
  OTHER
}
