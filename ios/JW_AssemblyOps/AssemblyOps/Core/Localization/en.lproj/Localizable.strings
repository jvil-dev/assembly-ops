"attendant.info.safety.upperLevels" = "Do not lean over railings or place items on upper-level ledges";
"attendant.info.safety.nonmedical" = "Non-medical emergency: immediately contact the attendant overseer";
"attendant.info.safety.flashlight" = "Each attendant should carry a flashlight for power failures";
"attendant.info.safety.medical" = "Medical emergency: contact First Aid immediately — they will call emergency services if needed";
"attendant.info.safety.reportInfo" = "When reporting an emergency, provide: type/scope, location, your name and phone number";

// Lost Persons & Threats
"attendant.info.lost.bringToLF" = "Bring lost persons (especially children) to the Lost & Found / Checkroom Department";
"attendant.info.lost.notifyOverseer" = "Immediately notify the attendant overseer of any lost person";
"attendant.info.lost.missingPerson" = "If someone is reported missing, inform the overseer and obtain identifying details and a photo";
"attendant.info.lost.bombThreat" = "Take ALL bomb threats seriously — immediately inform the attendant overseer";
"attendant.info.lost.noBombAlarm" = "DO NOT activate the fire alarm during a bomb threat";

// Escalators, Stage & Baptism
"attendant.info.facilities.escalators" = "Escalators and elevators should never be left unattended when in use";
"attendant.info.facilities.escalatorStop" = "Know how to emergency-stop escalators at your location";
