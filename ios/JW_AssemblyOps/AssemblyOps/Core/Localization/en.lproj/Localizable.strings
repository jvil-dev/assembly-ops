"attendant.info.conduct.badge" = "Always wear your attendant badge card while on duty";
"attendant.info.conduct.stayAssigned" = "Remain at your assignment until you are relieved or replaced";

// Entrances & Seating
"attendant.info.entrances.elderly8am" = "8:00 AM — Elderly and infirm (with one caregiver) may enter";
"attendant.info.entrances.general815" = "8:15 AM — General admission begins";
"attendant.info.entrances.checkExits" = "Check all exit doors daily — they must be unlocked and unobstructed";
"attendant.info.entrances.doorsNotPropped" = "Do not prop open exterior doors in climate-controlled buildings";
"attendant.info.entrances.noSeatSaving" = "No overnight seat-saving or saving seats before doors open each day";
