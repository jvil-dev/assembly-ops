// Bomb Threat (CO-23 §17)
"attendant.protocol.bombThreat.title" = "Bomb Threat Protocol";
"attendant.protocol.bombThreat.step1" = "Take the threat seriously. Do NOT activate the fire alarm.";
"attendant.protocol.bombThreat.step2" = "Immediately contact the attendant overseer or his assistant.";
"attendant.protocol.bombThreat.step3" = "Provide as much information as possible about the individual and the reported bomb.";
"attendant.protocol.bombThreat.step4" = "If a bomb is detonated, the fire alarm likely should be used at that point.";

// Violent Individual (CO-23 §23-24)
"attendant.protocol.violentIndividual.title" = "Disruptive / Violent Individual";
"attendant.protocol.violentIndividual.step1" = "Do not confront the individual alone. At least two attendants should approach together.";
"attendant.protocol.violentIndividual.step2" = "Attempt to speak with the person outside of the auditorium, away from others, and try to calm him.";
"attendant.protocol.violentIndividual.step3" = "If the person persists in being disruptive, ask him to leave and inform the attendant overseer immediately.";
"attendant.protocol.violentIndividual.step4" = "If the individual refuses to leave, inform him that the police will be contacted.";
"attendant.protocol.violentIndividual.step5" = "If the individual becomes violent, see the Avoid / Deny / Defend protocol for an active shooter situation.";

// Active Shooter (CO-23 §25-26)
"attendant.protocol.activeShooter.title" = "Active Shooter — Avoid / Deny / Defend";
"attendant.protocol.activeShooter.step1" = "AVOID: Pay attention to surroundings, have an exit plan, and quickly move away from the attacker.";
"attendant.protocol.activeShooter.step2" = "DENY: If you cannot avoid the attacker, create barriers, turn off lights, remain out of sight and quiet.";
"attendant.protocol.activeShooter.step3" = "DEFEND: Only as a last resort — protect yourself and others using any available means.";
"attendant.protocol.activeShooter.step4" = "Call the police immediately. Any attendant may call — do not wait for the overseer. Advise the overseer that police have been called.";
"attendant.protocol.activeShooter.step5" = "Direct attendees to escape routes away from the violence. If evacuation is not possible, encourage attendees to hide in locked rooms.";
"attendant.protocol.activeShooter.step6" = "Remain calm. Instruct others to silence phones and follow police directions immediately upon their arrival.";

