"attendant.info.entrances.assistElders" = "Assist elderly, disabled, and families with small children to find appropriate seating";

// Attendance Counting
"attendant.info.counting.informed" = "You will be informed of the specific times to take the attendance count";
"attendant.info.counting.noDistraction" = "Take the count without causing unnecessary distraction";
"attendant.info.counting.countAll" = "Count all adults and young children who are listening and benefiting from the program";

// Handling Distractions
"attendant.info.distractions.sources" = "Watch for: attendees talking, latecomers, cell phones, disruptive children, people in remote areas";
"attendant.info.distractions.kindly" = "Address distractions in a loving, kind manner";
"attendant.info.distractions.remote" = "Kindly suggest that people congregating in remote areas return to their seats";

// Safety & Emergencies
"attendant.info.safety.watch" = "Watch for: building defects, wet floors, objects in aisles, unsafe chairs, loose handrails";
"attendant.info.safety.wetFloors" = "Direct people around wet areas and report them to the Cleaning Department";
