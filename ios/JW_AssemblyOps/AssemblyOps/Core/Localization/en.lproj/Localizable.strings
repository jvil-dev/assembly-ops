// MARK: - Shift Reminders
"reminder.title" = "Pre-Shift Reminder";
"reminder.header" = "Mandatory Reminders";
"reminder.subtitle" = "Please read all reminders before starting your shift: %@";
"reminder.scrollHint" = "Scroll to the bottom to enable the confirmation button";
"reminder.listTitle" = "CO-23 Attendant Reminders";
"reminder.confirm" = "I've Read and Understood";
"reminder.item1.title" = "Be at Your Post on Time";
"reminder.item1.detail" = "Arrive at your assigned position no later than 15 minutes before doors open. Remain at your post until relieved or replaced. Wear your attendant badge at all times.";
"reminder.item2.title" = "Verify Exits and Evacuation Routes";
"reminder.item2.detail" = "Before the session, check that all exit doors in your area are unlocked and unobstructed from the inside. Know the appropriate evacuation route for your assigned section.";
"reminder.item3.title" = "Know Key Department Locations";
"reminder.item3.detail" = "Be familiar with how to reach First Aid, Lost & Found, the Attendant Overseer, and the Chairman's Office so you can direct attendees or report incidents quickly.";
"reminder.item4.title" = "Carry a Flashlight";
"reminder.item4.detail" = "Have a flashlight on your person in case of a power failure.";
"reminder.item5.title" = "Scan for Safety Hazards";
"reminder.item5.detail" = "Watch for building defects, objects in aisles, wet floors, faulty chairs, uneven surfaces, loose handrails, and railing gaps. Report anything you cannot correct to the attendant overseer.";
"reminder.item6.title" = "Emergency Reporting Protocol";
"reminder.item6.detail" = "When reporting any emergency, provide: (a) type and scope, (b) location, (c) your name, phone number, and location, and (d) any other helpful details.";
"reminder.item7.title" = "Violent Individual Response: Avoid, Deny, Defend";
"reminder.item7.detail" = "Avoid (move away), Deny (barricade/hide), Defend (protect yourself and others as last resort). In an active threat, anyone may call police immediately — do not wait for authorization.";
"reminder.item8.title" = "Handle Disruptions with Kindness";
"reminder.item8.detail" = "Approach concerns with at least two attendants. Attempt to calm agitated individuals and speak with them outside the auditorium. Escalate to the overseer if someone refuses to cooperate. Do not use force except in defense.";
"reminder.item9.title" = "Assist the Elderly, Disabled, and Families";
"reminder.item9.detail" = "Proactively help them find seating, navigate stairs, and use escalators/elevators safely. Treat all with dignity and respect.";
"reminder.item10.title" = "Know Your Attendance Count Timing";
"reminder.item10.detail" = "Be ready to count those in your assigned section at the designated times without causing unnecessary distraction. Count all adults and young children who are listening.";

