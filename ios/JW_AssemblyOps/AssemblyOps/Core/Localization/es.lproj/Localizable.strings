"reminder.title" = "Recordatorio Pre-Turno";
"reminder.header" = "Recordatorios Obligatorios";
"reminder.subtitle" = "Por favor lea todos los recordatorios antes de iniciar su turno: %@";
"reminder.scrollHint" = "Desplácese hasta el final para habilitar el botón de confirmación";
"reminder.listTitle" = "Recordatorios CO-23 para Acomodadores";
"reminder.confirm" = "He Leído y Comprendido";
"reminder.item1.title" = "Llegue a Su Puesto a Tiempo";
"reminder.item1.detail" = "Preséntese en su posición asignada al menos 15 minutos antes de que se abran las puertas. Permanezca en su puesto hasta ser relevado. Use su identificación de acomodador en todo momento.";
"reminder.item2.title" = "Verifique Salidas y Rutas de Evacuación";
"reminder.item2.detail" = "Antes de la sesión, compruebe que todas las puertas de salida de su área estén desbloqueadas y sin obstrucciones por dentro. Conozca la ruta de evacuación apropiada para su sección.";
"reminder.item3.title" = "Conozca la Ubicación de Departamentos Clave";
"reminder.item3.detail" = "Familiarícese con cómo llegar a Primeros Auxilios, Objetos Perdidos, el Superintendente de Acomodadores y la Oficina del Presidente para poder dirigir a los asistentes o reportar incidentes rápidamente.";
"reminder.item4.title" = "Lleve una Linterna";
"reminder.item4.detail" = "Tenga una linterna consigo en caso de falla eléctrica.";
"reminder.item5.title" = "Inspeccione los Peligros de Seguridad";
"reminder.item5.detail" = "Busque defectos del edificio, objetos en pasillos, pisos mojados, sillas defectuosas, superficies irregulares, barandillas sueltas y espacios en las barandillas. Reporte lo que no pueda corregir al superintendente.";
"reminder.item6.title" = "Protocolo de Reporte de Emergencias";
"reminder.item6.detail" = "Al reportar cualquier emergencia, proporcione: (a) tipo y alcance, (b) ubicación, (c) su nombre, teléfono y ubicación, y (d) cualquier otro detalle útil.";
"reminder.item7.title" = "Respuesta ante Individuo Violento: Evitar, Negar, Defender";
"reminder.item7.detail" = "Evitar (alejarse), Negar (barricarse/esconderse), Defender (protegerse a sí mismo y a otros como último recurso). Ante una amenaza activa, cualquiera puede llamar a la policía inmediatamente — no espere autorización.";
"reminder.item8.title" = "Maneje las Interrupciones con Bondad";
"reminder.item8.detail" = "Acérquese a los problemas con al menos dos acomodadores. Intente calmar a las personas agitadas y hable con ellas fuera del auditorio. Escale al superintendente si alguien se niega a cooperar. No use la fuerza excepto en defensa.";
"reminder.item9.title" = "Ayude a Ancianos, Discapacitados y Familias";
"reminder.item9.detail" = "Ayúdelos proactivamente a encontrar asientos, navegar escaleras y usar escaleras mecánicas/elevadores de forma segura. Trate a todos con dignidad y respeto.";
"reminder.item10.title" = "Conozca el Horario de Conteo de Asistencia";
"reminder.item10.detail" = "Esté listo para contar a los presentes en su sección asignada en los horarios designados sin causar distracciones innecesarias. Cuente a todos los adultos y niños pequeños que estén escuchando.";

